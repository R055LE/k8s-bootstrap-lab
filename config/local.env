# Local (Kind) environment configuration
# Referenced by Taskfile.yml and bootstrap/bootstrap.sh
#
# Sensitive values (passwords) are NOT stored here — bootstrap.sh generates
# them on first run and saves to config/local.secrets.env (gitignored).

# ── Cluster ──────────────────────────────────────────────────────────────────

KIND_CLUSTER_NAME=zero-to-cluster

# ── Gitea ─────────────────────────────────────────────────────────────────────

GITEA_NAMESPACE=gitea
GITEA_ADMIN_USER=gitea-admin
GITEA_REPO_NAME=zero-to-cluster

# Chart version — verify latest: helm search repo gitea-charts/gitea --versions | head -5
GITEA_CHART_VERSION=10.6.0

# In-cluster URL used by ArgoCD (accessible from argocd-repo-server pod)
REPO_URL=http://gitea-http.gitea.svc.cluster.local:3000/gitea-admin/zero-to-cluster.git
REPO_BRANCH=main

# ── ArgoCD ────────────────────────────────────────────────────────────────────

ARGOCD_NAMESPACE=argocd

# Chart version — verify latest: helm search repo argo/argo-cd --versions | head -5
ARGOCD_CHART_VERSION=7.7.5

# ── ingress-nginx ─────────────────────────────────────────────────────────────

INGRESS_NGINX_NAMESPACE=ingress-nginx

# Chart version — verify latest: helm search repo ingress-nginx/ingress-nginx --versions | head -5
INGRESS_NGINX_CHART_VERSION=4.11.3

# ── Monitoring (Phase 2) ──────────────────────────────────────────────────────

MONITORING_NAMESPACE=monitoring
LOGGING_NAMESPACE=logging

# Chart versions — verify latest with helm search repo
KUBE_PROMETHEUS_STACK_CHART_VERSION=65.3.1
LOKI_CHART_VERSION=6.16.0
PROMTAIL_CHART_VERSION=6.16.6

# ── Security (Phase 3) ────────────────────────────────────────────────────────

TRIVY_NAMESPACE=trivy-system
FALCO_NAMESPACE=falco

# Chart versions — verify latest with helm search repo
TRIVY_OPERATOR_CHART_VERSION=0.32.1
FALCO_CHART_VERSION=4.8.0
