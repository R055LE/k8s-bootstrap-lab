# AWS environment configuration — K8s Bootstrap Lab
# Copy to config/aws.env and fill in values.
# config/aws.env is gitignored — never commit the real file.
#
# Populated by setup-aws.sh after terraform apply:
#   LOKI_S3_BUCKET_NAME, LOKI_IRSA_ROLE_ARN, TRIVY_IRSA_ROLE_ARN
#
# Referenced by Taskfile.yml: dotenv: ['config/{{.TARGET}}.env']

# ── AWS ───────────────────────────────────────────────────────────────────────

AWS_REGION=us-east-1
AWS_PROFILE=default

# S3 bucket for Terraform state — must exist before running terraform init.
# Create it once with: bash scripts/create-tf-state-bucket.sh
TF_STATE_BUCKET=zero-to-cluster-tfstate-<your-account-id>

# ── Cluster ──────────────────────────────────────────────────────────────────

EKS_CLUSTER_NAME=zero-to-cluster

# ── Git source ────────────────────────────────────────────────────────────────
# ArgoCD on EKS uses GitHub (not in-cluster Gitea — no git server needed on EKS).
# For private repos, add a deploy key: see docs/troubleshooting.md

REPO_URL=https://github.com/R055LE/k8s-bootstrap-lab.git
REPO_BRANCH=main

# ── ArgoCD ────────────────────────────────────────────────────────────────────

ARGOCD_NAMESPACE=argocd
ARGOCD_CHART_VERSION=7.7.5

# ── ingress-nginx ─────────────────────────────────────────────────────────────

INGRESS_NGINX_NAMESPACE=ingress-nginx
INGRESS_NGINX_CHART_VERSION=4.11.3

# ── Monitoring ────────────────────────────────────────────────────────────────

MONITORING_NAMESPACE=monitoring
LOGGING_NAMESPACE=logging
KUBE_PROMETHEUS_STACK_CHART_VERSION=65.3.1
LOKI_CHART_VERSION=6.16.0
PROMTAIL_CHART_VERSION=6.16.6

# ── Security ──────────────────────────────────────────────────────────────────

TRIVY_NAMESPACE=trivy-system
FALCO_NAMESPACE=falco
TRIVY_OPERATOR_CHART_VERSION=0.32.1
FALCO_CHART_VERSION=4.8.0

# ── Terraform outputs (written by setup-aws.sh after terraform apply) ─────────

LOKI_S3_BUCKET_NAME=
LOKI_IRSA_ROLE_ARN=
TRIVY_IRSA_ROLE_ARN=
