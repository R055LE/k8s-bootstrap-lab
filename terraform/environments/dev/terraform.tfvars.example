# Copy to terraform.tfvars and fill in your values.
# terraform.tfvars is gitignored — never commit the real file.

aws_region  = "us-east-1"
aws_profile = "default"

cluster_name       = "zero-to-cluster"
environment        = "dev"
kubernetes_version = "1.31"

node_instance_type = "t3.medium"
node_desired_count = 2
node_min_count     = 1
node_max_count     = 3

vpc_cidr = "10.0.0.0/16"

# Must be globally unique across all AWS accounts
loki_s3_bucket_name = "zero-to-cluster-loki-logs-<your-account-id>"
